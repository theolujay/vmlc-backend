# .example.env - Environment Variables for VMLC Backend
# This file lists all environment variables used by the VMLC Backend.
# Copy this file to .env, prod.env, staging.env, or test.env and fill in the values.

# ============================================================================
# CORE DJANGO SETTINGS
# ============================================================================
# A secret key for a particular Django installation. This is used to provide
# cryptographic signing, and should be a unique, unpredictable value.
# KEEP THIS SECRET! In production, generate a strong, random string.
SECRET_KEY=your_super_secret_key_here_for_prod_or_staging

# Set to 'True' for development, 'False' for production/staging.
# Controls debug output and error pages.
DEBUG=True

# Comma-separated list of strings representing the host/domain names that this Django site can serve.
# In production, this should be a list of your domain names (e.g., example.com, www.example.com).
# In development, you might include localhost, 127.0.0.1.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of IP addresses that are allowed to see the debug toolbar (in DEBUG mode).
INTERNAL_IPS=127.0.0.1

# The URL path where the Django Admin interface is accessible.
DJANGO_ADMIN_URL=admin/

# ============================================================================
# DATABASE SETTINGS
# ============================================================================
# Full database connection URL. Examples:
# PostgreSQL: postgresql://user:password@host:port/dbname
# SQLite (for local dev): sqlite:///./db.sqlite3
# Neon DB (for local dev): postgres://user:password@ep-random-name-12345.aws-east-2.neon.tech/dbname
DATABASE_URL=

# Only for local development (dev.py) if using Neon DB.
# If not using Neon, SQLite will be used by default.
NEON_DB_URL=

# Default PostgreSQL user for Docker development environment (docker_dev.py).
POSTGRES_USER=postgres
# Default PostgreSQL password for Docker development environment (docker_dev.py).
POSTGRES_PASSWORD=password
# Default PostgreSQL database name for Docker development environment (docker_dev.py).
POSTGRES_DB=vmlc_dev

# ============================================================================
# AWS S3 STORAGE SETTINGS (for media and static files)
# ============================================================================
# Set to 'True' to enable AWS S3 for file storage. Requires AWS credentials below.
# Set to 'False' to use local file system storage.
USE_S3=False

# Your AWS Access Key ID.
AWS_ACCESS_KEY_ID=
# Your AWS Secret Access Key.
AWS_SECRET_ACCESS_KEY=
# The name of your S3 bucket.
AWS_STORAGE_BUCKET_NAME=
# The AWS region where your S3 bucket is located (e.g., us-east-1).
AWS_S3_REGION_NAME=
# A prefix for S3 paths, useful for separating environments (e.g., 'dev', 'staging', 'prod').
AWS_S3_LOCATION_PREFIX=dev

# ============================================================================
# EMAIL CONFIGURATION (SMTP)
# ============================================================================
# Email backend to use. Defaults to SMTP.
# Use 'django.core.mail.backends.console.EmailBackend' for local testing without sending actual emails.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# SMTP host for sending emails (e.g., smtp.sendgrid.net, smtp.gmail.com).
EMAIL_HOST=
# SMTP port (e.g., 587 for TLS, 465 for SSL).
EMAIL_PORT=587
# Username for SMTP authentication.
EMAIL_HOST_USER=
# Password for SMTP authentication.
EMAIL_HOST_PASSWORD=
# Set to 'True' to use TLS encryption (recommended for port 587).
EMAIL_USE_TLS=True
# Set to 'True' to use SSL encryption (recommended for port 465).
EMAIL_USE_SSL=False
# The default 'From' email address for outgoing emails.
DEFAULT_FROM_EMAIL=noreply@example.com
# Support email address displayed in application.
SUPPORT_EMAIL=support@example.com
# Server email address for automated messages.
SERVER_EMAIL=server@example.com

# ============================================================================
# APPLICATION URLS
# ============================================================================
# Base URL of the backend API (e.g., http://localhost:8000, https://api.example.com).
BASE_URL=http://localhost:8000
# URL for the Terms of Service page.
TOS_URL=${BASE_URL}/terms/
# Contact email address for the application.
CONTACT_EMAIL=contact@example.com
# URL for the contact page.
CONTACT_URL=${BASE_URL}/contact/
# URL for the license information page.
LICENSE_URL=${BASE_URL}/license/
# URL for the application logo image.
LOGO_URL=${BASE_URL}/static/images/logo.png

# Base URL of the frontend application (e.g., http://localhost:3000, https://app.example.com).
FRONTEND_BASE_URL=http://localhost:3000

# ============================================================================
# THIRD-PARTY SERVICE KEYS
# ============================================================================
# Twilio Account SID for SMS services.
TWILIO_ACCOUNT_SID=
# Twilio Auth Token for SMS services.
TWILIO_AUTH_TOKEN=
# Twilio phone number to send messages from (e.g., +15017122661).
TWILIO_FROM_PHONE=

# Slack webhook URL for notifications.
SLACK_WEBHOOK_URL=
# Webhook URL for broadcasting notifications (e.g., Discord, custom systems).
BROADCAST_WEBHOOK_URL=

# ============================================================================
# CORS (Cross-Origin Resource Sharing) SETTINGS
# ============================================================================
# Comma-separated list of origins that are allowed to make cross-site HTTP requests.
# (e.g., http://localhost:3000,https://app.example.com)
CORS_ALLOWED_ORIGINS=

# Set to 'True' to allow credentials (cookies, HTTP authentication, client-side SSL certificates)
# to be included in cross-origin requests.
CORS_ALLOW_CREDENTIALS=False

# Set to 'True' to allow all origins. Not recommended for production.
CORS_ALLOW_ALL_ORIGINS=False

# ============================================================================
# REDIS / CACHE SETTINGS
# ============================================================================
# Redis host for Django Channels layer.
REDIS_HOST=127.0.0.1
# Redis port for Django Channels layer.
REDIS_PORT=6379

# Redis URL for Django's cache backend.
# Example: redis://localhost:6379/1 (for local) or redis://redis:6379/1 (for Docker)
CACHE_REDIS_URL=redis://localhost:6379/1

# ============================================================================
# CELERY ASYNCHRONOUS TASK QUEUE SETTINGS
# ============================================================================
# URL for the Celery message broker (e.g., redis://localhost:6379/0).
CELERY_BROKER_URL=redis://localhost:6379/0
# URL for storing Celery task results (e.g., redis://localhost:6379/0).
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Set to 'True' to execute Celery tasks immediately and synchronously in the same process.
# Useful for development and testing. Should be 'False' in production.
CELERY_ALWAYS_EAGER=False

# ============================================================================
# FILE UPLOAD LIMITS
# ============================================================================
# Maximum amount of data that will be read into memory from a POST request.
# Default 2MB (2 * 1024 * 1024)
DATA_UPLOAD_MAX_MEMORY_SIZE=2097152
# Maximum size, in bytes, that a file upload can be before it's streamed to disk.
# Default 2MB (2 * 1024 * 1024)
FILE_UPLOAD_MAX_MEMORY_SIZE=2097152

# ============================================================================
# LOGGING & MONITORING
# ============================================================================
# Set to 'True' to enable logging of all database queries (for debug environments).
LOG_QUERIES=False
# Set to 'True' to enable logging of all incoming HTTP requests (for debug environments).
LOG_REQUESTS=False

# OpenTelemetry OTLP endpoint (e.g., http://localhost:4317).
OTEL_EXPORTER_OTLP_ENDPOINT=
# Set to 'True' to enable automatic OpenTelemetry logging instrumentation.
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=False
