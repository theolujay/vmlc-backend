		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login (Candidate)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access) {",
									"    pm.collectionVariables.set(\"candidateAccessToken\", jsonData.access);",
									"}",
									"if (jsonData.refresh) {",
									"    pm.collectionVariables.set(\"candidateRefreshToken\", jsonData.refresh);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
